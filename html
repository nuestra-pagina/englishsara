<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>HTML, CSS & JavaScript</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,wght@0,400;0,600;0,700;1,500&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
<style>
  :root{
    --bg: #0e0e1a;
    --bg2: #14142a;
    --panel: #1a1a30;
    --panel-line: #2b2b48;
    --text: #f2f2f7;
    --muted: #9a9ab0;
    --accent: #E34F26;
    --accent-soft: #E34F2622;
    --radius: 20px;
  }
  *{ box-sizing:border-box; }
  html,body{
    margin:0; padding:0; height:100%;
    background: var(--bg);
    color: var(--text);
    font-family: 'Inter', sans-serif;
    overflow: hidden;
    transition: background 0.6s ease;
  }
  body[data-slide="0"]{ --accent:#8b8bd8; }
  body[data-slide="1"]{ --accent:#E34F26; }
  body[data-slide="2"]{ --accent:#2E86F0; }
  body[data-slide="3"]{ --accent:#F7DF1E; }
  body[data-slide="4"]{ --accent:#42e2a8; }
 
  /* floating ambient blobs */
  .blob{
    position:fixed; border-radius:50%; filter: blur(70px);
    opacity:0.35; z-index:0; pointer-events:none;
    transition: background 0.8s ease;
  }
  .blob1{ width:420px; height:420px; top:-120px; left:-100px; background: var(--accent); animation: float1 16s ease-in-out infinite; }
  .blob2{ width:340px; height:340px; bottom:-100px; right:-80px; background: var(--accent); animation: float2 20s ease-in-out infinite; opacity:0.22;}
  .blob3{ width:260px; height:260px; top:40%; right:10%; background: #ffffff; animation: float3 24s ease-in-out infinite; opacity:0.05; }
  @keyframes float1{
    0%,100%{ transform: translate(0,0) scale(1); }
    50%{ transform: translate(60px,50px) scale(1.15); }
  }
  @keyframes float2{
    0%,100%{ transform: translate(0,0) scale(1); }
    50%{ transform: translate(-40px,-40px) scale(1.1); }
  }
  @keyframes float3{
    0%,100%{ transform: translate(0,0); }
    50%{ transform: translate(-80px,40px); }
  }
 
  .deck{
    position:relative; z-index:1;
    width:100vw; height:100vh;
    overflow:hidden;
  }
  .track{
    display:flex; height:100%;
    transition: transform 0.7s cubic-bezier(.65,0,.35,1);
  }
  .slide{
    min-width:100vw; height:100%;
    display:flex; align-items:center; justify-content:center;
    padding: 60px 90px;
  }
 
  /* ---------- nav ---------- */
  .nav{
    position:fixed; bottom:28px; left:50%; transform:translateX(-50%);
    display:flex; gap:12px; z-index:10; align-items:center;
    background: rgba(255,255,255,0.04);
    border:1px solid rgba(255,255,255,0.08);
    padding:10px 16px; border-radius:999px;
    backdrop-filter: blur(10px);
  }
  .dot{
    width:9px; height:9px; border-radius:50%;
    background: rgba(255,255,255,0.25);
    cursor:pointer; transition: all 0.3s ease;
    border:none; padding:0;
  }
  .dot.active{ background: var(--accent); width:26px; border-radius:6px; }
 
  .arrow{
    position:fixed; top:50%; transform:translateY(-50%);
    width:52px; height:52px; border-radius:50%;
    background: rgba(255,255,255,0.05);
    border:1px solid rgba(255,255,255,0.1);
    color: var(--text); font-size:20px; cursor:pointer;
    display:flex; align-items:center; justify-content:center;
    z-index:10; transition: all 0.25s ease;
    backdrop-filter: blur(6px);
  }
  .arrow:hover{ background: var(--accent); color:#12121f; border-color: var(--accent); transform: translateY(-50%) scale(1.08); }
  .arrow.left{ left:28px; }
  .arrow.right{ right:28px; }
  .arrow:disabled{ opacity:0.25; pointer-events:none; }
 
  .eyebrow{
    font-family:'JetBrains Mono', monospace; font-size:13px;
    letter-spacing:3px; text-transform:uppercase; color:var(--accent);
    margin-bottom:14px; display:flex; align-items:center; gap:10px;
    transition: color 0.6s ease;
  }
  .eyebrow::before{
    content:''; display:inline-block; width:26px; height:2px; background:var(--accent);
  }
  h1.big{
    font-family:'Fraunces', serif; font-weight:700; font-size:clamp(40px,5vw,72px);
    line-height:1.05; margin:0 0 18px 0; letter-spacing:-0.02em;
  }
  p.lead{ font-size:19px; color:var(--muted); line-height:1.6; max-width:520px; margin:0 0 8px 0;}
 
  /* ---------- browser mock ---------- */
  .browser{
    background: var(--panel);
    border:1px solid var(--panel-line);
    border-radius: 14px;
    overflow:hidden;
    box-shadow: 0 30px 80px -20px rgba(0,0,0,0.6);
  }
  .browser-bar{
    display:flex; align-items:center; gap:8px;
    padding:12px 16px; background: rgba(255,255,255,0.03);
    border-bottom:1px solid var(--panel-line);
  }
  .browser-dot{ width:10px; height:10px; border-radius:50%; }
  .browser-url{
    margin-left:10px; font-family:'JetBrains Mono',monospace; font-size:11px;
    color:var(--muted); background: rgba(255,255,255,0.04);
    padding:4px 10px; border-radius:6px; flex:1;
  }
 
  pre.code{
    margin:0; padding:20px 22px; font-family:'JetBrains Mono', monospace;
    font-size:14.5px; line-height:1.7; color:#e6e6f0; min-height:150px;
    white-space: pre-wrap; word-break: break-word;
  }
  .code .tag{ color: var(--accent); }
  .code .str{ color:#9fe6a0; }
  .code .cmt{ color:#6c6c88; }
  .code .kw{ color:#7fb5ff; }
 
  .cursor{
    display:inline-block; width:8px; height:16px; background: var(--accent);
    vertical-align:middle; animation: blink 0.9s step-end infinite; margin-left:2px;
  }
  @keyframes blink{ 50%{ opacity:0; } }
 
  .preview{
    border-top:1px solid var(--panel-line);
    padding:26px 24px; min-height:110px;
    background: #0c0c18;
    display:flex; align-items:center; justify-content:center; flex-direction:column; gap:10px;
  }
 
  /* two-col layout */
  .cols{ display:flex; gap:64px; align-items:center; max-width:1180px; width:100%; }
  .col-text{ flex: 0 0 420px; }
  .col-visual{ flex:1; }
 
  /* ---------- title slide ---------- */
  .title-badges{ display:flex; gap:14px; margin-bottom:36px; }
  .badge{
    display:flex; align-items:center; gap:8px;
    padding:8px 16px; border-radius:999px;
    background: rgba(255,255,255,0.05); border:1px solid rgba(255,255,255,0.09);
    font-family:'JetBrains Mono',monospace; font-size:12.5px; color:var(--muted);
    animation: pop 0.6s ease both;
  }
  .badge span.sw{ width:9px; height:9px; border-radius:50%; }
  .badge:nth-child(1){ animation-delay: 0.05s;}
  .badge:nth-child(2){ animation-delay: 0.2s;}
  .badge:nth-child(3){ animation-delay: 0.35s;}
  @keyframes pop{ from{ opacity:0; transform:translateY(10px);} to{ opacity:1; transform:translateY(0);} }
 
  .title-center{ text-align:center; max-width:820px; margin:0 auto; }
  .title-center h1{ font-size:clamp(46px,6vw,84px); }
  .title-center p.lead{ margin:0 auto; text-align:center; }
  .hint{
    margin-top:50px; font-size:13px; color:var(--muted);
    display:flex; align-items:center; justify-content:center; gap:8px;
    font-family:'JetBrains Mono',monospace;
  }
  .hint .k{
    border:1px solid rgba(255,255,255,0.15); border-radius:6px; padding:2px 8px;
    animation: nudge 1.6s ease-in-out infinite;
  }
  @keyframes nudge{ 0%,100%{ transform:translateX(0);} 50%{ transform:translateX(6px);} }
 
  /* ---------- summary cards ---------- */
  .cards{ display:flex; gap:26px; }
  .card{
    flex:1; background: var(--panel); border:1px solid var(--panel-line);
    border-radius:18px; padding:30px 26px; text-align:left;
    transition: transform 0.35s ease, box-shadow 0.35s ease, border-color 0.35s ease;
  }
  .card:hover{ transform: translateY(-10px); box-shadow: 0 24px 50px -18px rgba(0,0,0,0.55); }
  .card .dot-icon{ width:34px; height:34px; border-radius:10px; margin-bottom:18px; }
  .card h3{ font-family:'Fraunces',serif; font-size:22px; margin:0 0 8px 0; }
  .card p{ color:var(--muted); font-size:14px; line-height:1.55; margin:0; }
  .card:nth-child(1) .dot-icon{ background:#E34F26; }
  .card:nth-child(2) .dot-icon{ background:#2E86F0; }
  .card:nth-child(3) .dot-icon{ background:#F7DF1E; }
 
  .summary-tag{ text-align:center; margin-top:34px; color:var(--muted); font-family:'Fraunces',serif; font-style:italic; font-size:19px; }
 
  .counter-btn{
    font-family:'Inter',sans-serif; font-weight:600; font-size:14px;
    background: var(--accent); color:#0c0c18; border:none;
    padding:11px 22px; border-radius:10px; cursor:pointer;
    transition: transform 0.15s ease;
  }
  .counter-btn:active{ transform: scale(0.94); }
  .counter-out{ font-family:'JetBrains Mono',monospace; color:var(--text); font-size:14px; opacity:0.85; }
  .pulse{ animation: pulse 0.4s ease; }
  @keyframes pulse{ 0%{ transform:scale(1);} 40%{ transform:scale(1.12);} 100%{ transform:scale(1);} }
 
  .plain-h1{ font-size:26px; font-weight:400; font-family: Georgia, serif; color:#cfcfe0; margin:0; }
  .plain-p{ font-size:14px; color:#8f8fa8; margin:0; font-family: Georgia, serif;}
  .styled-h1{ font-size:28px; font-weight:700; color:#2E86F0; margin:0; text-align:center; transition: all 0.5s ease; font-family:'Inter',sans-serif;}
  .styled-p{ font-size:14px; color:#999; margin:0; text-align:center; transition: all 0.5s ease;}
 
  @media (max-width: 900px){
    .cols{ flex-direction:column; }
    .col-text{ flex-basis:auto; }
    .cards{ flex-direction:column; }
    .slide{ padding: 40px 24px; }
  }
</style>
</head>
<body data-slide="0">
 
<div class="blob blob1"></div>
<div class="blob blob2"></div>
<div class="blob blob3"></div>
 
<div class="deck">
  <div class="track" id="track">
 
    <!-- SLIDE 0: TITLE -->
    <section class="slide">
      <div class="title-center">
        <div class="title-badges" style="justify-content:center;">
          <div class="badge"><span class="sw" style="background:#E34F26;"></span>HTML</div>
          <div class="badge"><span class="sw" style="background:#2E86F0;"></span>CSS</div>
          <div class="badge"><span class="sw" style="background:#F7DF1E;"></span>JavaScript</div>
        </div>
        <h1 class="big">The three layers<br>of every web page</h1>
        <p class="lead">A short walkthrough, with real live examples, of what each language does — and how they build on top of one another.</p>
        <div class="hint">Daysi Sara Rivas Lemus <span class="k">.</span></div>
      </div>
    </section>
 
    <!-- SLIDE 1: HTML -->
    <section class="slide">
      <div class="cols">
        <div class="col-text">
          <div class="eyebrow">01 · Structure</div>
          <h1 class="big">HTML</h1>
          <p class="lead">It's the <strong>skeleton</strong> of the page. It defines what content exists — headings, paragraphs, links, images — using tags that wrap the content.</p>
          <p class="lead">No styling yet: the browser just reads the structure and shows it in its most basic form.</p>
        </div>
        <div class="col-visual">
          <div class="browser">
            <div class="browser-bar">
              <div class="browser-dot" style="background:#E34F26;"></div>
              <div class="browser-dot" style="background:#F7DF1E;"></div>
              <div class="browser-dot" style="background:#42e2a8;"></div>
              <div class="browser-url">index.html</div>
            </div>
            <pre class="code" id="code-html"></pre>
            <div class="preview" id="preview-html"></div>
          </div>
        </div>
      </div>
    </section>
 
    <!-- SLIDE 2: CSS -->
    <section class="slide">
      <div class="cols">
        <div class="col-text">
          <div class="eyebrow">02 · Presentation</div>
          <h1 class="big">CSS</h1>
          <p class="lead">It's the <strong>clothing and decoration</strong> for that structure. It chooses colors, fonts, sizes, and spacing.</p>
          <p class="lead">Same HTML from before — now with style rules applied on top.</p>
        </div>
        <div class="col-visual">
          <div class="browser">
            <div class="browser-bar">
              <div class="browser-dot" style="background:#E34F26;"></div>
              <div class="browser-dot" style="background:#F7DF1E;"></div>
              <div class="browser-dot" style="background:#42e2a8;"></div>
              <div class="browser-url">style.css</div>
            </div>
            <pre class="code" id="code-css"></pre>
            <div class="preview" id="preview-css">
              <div class="styled-h1" id="css-h1">Hello, world!</div>
              <div class="styled-p" id="css-p">This is my page.</div>
            </div>
          </div>
        </div>
      </div>
    </section>
 
    <!-- SLIDE 3: JS -->
    <section class="slide">
      <div class="cols">
        <div class="col-text">
          <div class="eyebrow">03 · Behavior</div>
          <h1 class="big">JavaScript</h1>
          <p class="lead">It's the <strong>electricity</strong>: it makes the page react. It listens for clicks, changes content, computes things — without reloading the page.</p>
          <p class="lead">Try the button on the right — it actually works. ⚡</p>
        </div>
        <div class="col-visual">
          <div class="browser">
            <div class="browser-bar">
              <div class="browser-dot" style="background:#E34F26;"></div>
              <div class="browser-dot" style="background:#F7DF1E;"></div>
              <div class="browser-dot" style="background:#42e2a8;"></div>
              <div class="browser-url">script.js</div>
            </div>
            <pre class="code" id="code-js"></pre>
            <div class="preview" id="preview-js" style="flex-direction:row; gap:16px;">
              <button class="counter-btn" id="counter-btn">Click me</button>
              <span class="counter-out" id="counter-out">clicks: 0</span>
            </div>
          </div>
        </div>
      </div>
    </section>
 
    
    <section class="slide">
      <div style="max-width:1000px; width:100%;">
        <div class="eyebrow" style="justify-content:center;">Summary</div>
        <h1 class="big" style="text-align:center;">Three languages,<br>In conclusion</h1>
        <div class="cards" style="margin-top:44px;">
          <div class="card">
            <div class="dot-icon"></div>
            <h3>HTML structures</h3>
            <p>Puts in the content: whatever exists on the page.</p>
          </div>
          <div class="card">
            <div class="dot-icon"></div>
            <h3>CSS styles</h3>
            <p>Defines how it looks: colors, typography, layout.</p>
          </div>
          <div class="card">
            <div class="dot-icon"></div>
            <h3>JS animates</h3>
            <p>Gives it behavior: interaction and logic.</p>
          </div>
        </div>
        <p class="summary-tag">"A website is created using these three elements."</p>
      </div>
    </section>
 
  </div>
</div>
 
<button class="arrow left" id="arrow-left">‹</button>
<button class="arrow right" id="arrow-right">›</button>
<div class="nav" id="nav"></div>
 
<script>
  const total = 5;
  let current = 0;
  const track = document.getElementById('track');
  const nav = document.getElementById('nav');
  const arrowLeft = document.getElementById('arrow-left');
  const arrowRight = document.getElementById('arrow-right');
 
  for(let i=0;i<total;i++){
    const d = document.createElement('button');
    d.className = 'dot' + (i===0?' active':'');
    d.addEventListener('click', ()=>goTo(i));
    nav.appendChild(d);
  }
 
  function updateDots(){
    [...nav.children].forEach((d,i)=> d.classList.toggle('active', i===current));
  }
 
  function goTo(i){
    if(i<0||i>=total) return;
    current = i;
    track.style.transform = `translateX(-${i*100}vw)`;
    document.body.setAttribute('data-slide', i);
    updateDots();
    arrowLeft.disabled = i===0;
    arrowRight.disabled = i===total-1;
    triggerSlideAnimation(i);
  }
 
  arrowLeft.addEventListener('click', ()=>goTo(current-1));
  arrowRight.addEventListener('click', ()=>goTo(current+1));
  document.addEventListener('keydown', (e)=>{
    if(e.key==='ArrowRight') goTo(current+1);
    if(e.key==='ArrowLeft') goTo(current-1);
  });
 
  /* ---------- typing effect ---------- */
  function typeInto(el, html, speed=16){
    return new Promise(resolve=>{
      el.innerHTML = '';
      let i = 0;
      // strip to plain text sequence but keep tag markup by chunking on tags
      const parts = html.split(/(<[^>]+>)/g).filter(Boolean);
      let buffer = '';
      let pi = 0;
      function step(){
        if(pi>=parts.length){ resolve(); return; }
        const part = parts[pi];
        if(part.startsWith('<')){
          buffer += part;
          el.innerHTML = buffer + '<span class="cursor"></span>';
          pi++;
          setTimeout(step, 4);
        } else {
          if(i < part.length){
            buffer += part[i];
            el.innerHTML = buffer + '<span class="cursor"></span>';
            i++;
            setTimeout(step, speed);
          } else {
            i = 0; pi++;
            setTimeout(step, 4);
          }
        }
      }
      step();
    });
  }
 
  const htmlCode = `<span class="tag">&lt;h1&gt;</span>Hello, world!<span class="tag">&lt;/h1&gt;</span>\n<span class="tag">&lt;p&gt;</span>This is my page.<span class="tag">&lt;/p&gt;</span>`;
  const cssCode = `<span class="kw">h1</span> {\n  color: <span class="str">#2E86F0</span>;\n  text-align: <span class="str">center</span>;\n}\n<span class="kw">p</span> { color: <span class="str">#999</span>; }`;
  const jsCode = `button.<span class="kw">addEventListener</span>(<span class="str">'click'</span>, () =&gt; {\n  count++;\n  output.textContent = <span class="str">\`clicks: \${count}\`</span>;\n});`;
 
  let played = { 1:false, 2:false, 3:false };
 
  async function triggerSlideAnimation(i){
    if(i===1 && !played[1]){
      played[1]=true;
      await typeInto(document.getElementById('code-html'), htmlCode, 18);
      const p = document.getElementById('preview-html');
      p.innerHTML = '<div class="plain-h1">Hello, world!</div><div class="plain-p" style="margin-top:6px;">This is my page.</div>';
    }
    if(i===2 && !played[2]){
      played[2]=true;
      await typeInto(document.getElementById('code-css'), cssCode, 18);
    }
    if(i===3 && !played[3]){
      played[3]=true;
      await typeInto(document.getElementById('code-js'), jsCode, 18);
    }
  }
 
  // pre-fill html code instantly once at load isn't needed; first slide is title.
  arrowLeft.disabled = true;
 
  /* live counter — real working JS */
  let count = 0;
  const counterBtn = document.getElementById('counter-btn');
  const counterOut = document.getElementById('counter-out');
  counterBtn.addEventListener('click', ()=>{
    count++;
    counterOut.textContent = `clicks: ${count}`;
    counterOut.classList.remove('pulse');
    void counterOut.offsetWidth;
    counterOut.classList.add('pulse');
  });
</script>
</body>
</html>
 